{
  "name": "vio83-ai-orchestra",
  "private": true,
  "version": "0.9.0-beta",
  "type": "module",
  "description": "Local-first AI orchestration desktop app for macOS. React + Tauri frontend, FastAPI backend, Ollama runtime, evidence-aware knowledge base.",
  "author": "Viorica Porcu <porcu.v.83@gmail.com> (https://github.com/vio83)",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://vio83.github.io/vio83-ai-orchestra/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vio83/vio83-ai-orchestra.git"
  },
  "bugs": {
    "url": "https://github.com/vio83/vio83-ai-orchestra/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/vio83"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/vio83"
    }
  ],
  "keywords": [
    "ai-orchestration",
    "local-ai",
    "ollama",
    "rag-engine",
    "knowledge-base",
    "sqlite-fts5",
    "tauri",
    "desktop-app",
    "react-typescript",
    "fastapi",
    "privacy-first",
    "macos",
    "open-source-ai"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src eslint.config.js vite.config.ts vitest.config.ts tests/frontend --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "test:frontend": "vitest run",
    "test:backend": "python3 -m unittest discover -s tests/backend -p 'test_*.py'",
    "backend:compile": "python3 -m compileall backend",
    "e2e:backend-smoke": "bash scripts/ci/backend_smoke.sh",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release:gate": "npm run typecheck && npm run lint && npm run test:frontend && npm run build && npm run tauri:build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "framer-motion": "^12.34.2",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.574.0",
    "ollama": "^0.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
