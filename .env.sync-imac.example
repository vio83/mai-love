# Copy to: ~/.config/vio83-sync.env
# Safe peer sync config for iMac Arch <- Mac Air over Tailscale / SSH

# Example: PEER_HOST=100.x.y.z or macair.local
PEER_HOST=
PEER_USER=padronavio
PEER_SSH_TARGET=

# Remote macOS source paths on the Mac Air
PEER_REPO_DIR="/Users/padronavio/Projects/vio83-ai-orchestra"
PEER_VSCODE_DIR="/Users/padronavio/Library/Application Support/Code/User"

# Local destination paths on the iMac
LOCAL_REPO_DIR=
LOCAL_VSCODE_DIR=

# Sync cadence in seconds. 1 = very aggressive, 3-5 = recommended.
IMAC_SYNC_INTERVAL_SEC=1
