# ============================================================
# VIO 83 AI ORCHESTRA - Configurazione API Keys
# Copyright (c) 2026 Viorica Porcu (vio83). All Rights Reserved.
# ============================================================
# Copia questo file come .env e inserisci le tue chiavi:
#   cp .env.example .env
#
# NON committare MAI il file .env su Git!
# ORDINE: Gratis → Economici → Standard
# ============================================================

# ─── PROVIDER GRATUITI (API key gratis, limiti generosi) ───

# Groq — 14,400 richieste/giorno GRATIS
# Registrati: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Together AI — $1 credito gratis alla registrazione
# Registrati: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — Modelli gratuiti illimitati + $1 credito
# Registrati: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PROVIDER ECONOMICI (< $1 per 1M token) ───

# DeepSeek — $0.27/1M token input, ottimo per code e reasoning
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mistral — $0.20/1M token input, ottimo multilingue
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PROVIDER STANDARD (a pagamento) ───

# Anthropic (Claude) — Il migliore per code, analisi, ragionamento
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT-4) — Ottimo per creatività e multimodalità
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# xAI (Grok) — Ottimo per info in tempo reale
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (Gemini) — 1M token context, multimodale
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MONETIZATION / OBSERVABILITY (P0) ───

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Error monitoring
SENTRY_DSN=
# VIO_ENV: development | staging | production
VIO_ENV=development

# Product analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
# Frontend PostHog (Vite env — copia in .env con valore reale)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Perplexity Agent API — ricerca web grounded, preset pro-search / deep-research
PERPLEXITY_API_KEY=pplx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CONFIGURAZIONE LOCALE ───

# Ollama (locale, sempre gratis)
OLLAMA_HOST=http://localhost:11434

# Porta backend VIO 83 AI Orchestra
LITELLM_PROXY_PORT=4000

# ─── RUNTIME SERVICES SUPERVISOR (OpenClaw / LegalRoom / n8n) ───
# Il supervisor locale usa questi comandi per mantenere verdi i target Health Panel.
# Inserisci i comandi REALI per i tuoi servizi locali:
OPENCLAW_START_CMD=
LEGALROOM_START_CMD=

# n8n: opzionale. Se vuoto, il supervisor usa fallback automatico
# (Docker -> nvm node22 -> npx).
N8N_START_CMD=

# Health endpoint (coerenti con Runtime 360)
OPENCLAW_HEALTH_URLS=http://127.0.0.1:4111/health,http://127.0.0.1:4111/
LEGALROOM_HEALTH_URLS=http://127.0.0.1:4222/health,http://127.0.0.1:4222/
N8N_HEALTH_URLS=http://127.0.0.1:5678/healthz,http://127.0.0.1:5678/rest/healthz,http://127.0.0.1:5678/

# Tuning supervisor
RUNTIME_SUPERVISOR_TICK_SEC=8
RUNTIME_SUPERVISOR_UNHEALTHY_RESTART_SEC=45
RUNTIME_SUPERVISOR_RESTART_BACKOFF_SEC=15

# Policy utente per app runtime esterne
RUNTIME_APPS_UPDATE_POLICY=user-approved
RUNTIME_APPS_OFFLINE_MODE=keep-last-approved
RUNTIME_APPS_LAST_USER_APPROVED_AT=

# ─── AUTONOMOUS RUNTIME (trigger → route → session namespace) ───
# Memoria persistente Markdown + compattazione + scheduler + webhook + file-watch
AUTONOMOUS_RUNTIME_ENABLED=true
AUTONOMOUS_RUNTIME_HEARTBEAT_SEC=300
AUTONOMOUS_RUNTIME_WATCH_POLL_SEC=90
AUTONOMOUS_RUNTIME_COMPACT_EVERY_NOTES=12
AUTONOMOUS_RUNTIME_CONTEXT_TAIL_NOTES=12
AUTONOMOUS_RUNTIME_DEFAULT_ACCOUNT=vio83-local
AUTONOMOUS_RUNTIME_DEFAULT_CHANNEL=main
AUTONOMOUS_RUNTIME_CRON_UTC=00:15,06:15,12:15,18:15
AUTONOMOUS_RUNTIME_WATCH_DIRS=backend,src,docs,data/config
AUTONOMOUS_RUNTIME_WATCH_EXTENSIONS=.py,.ts,.tsx,.js,.jsx,.md,.json,.yml,.yaml,.toml,.sh
AUTONOMOUS_RUNTIME_BACKGROUND_ISOLATION=true
AUTONOMOUS_RUNTIME_MAX_FILES_PER_TICK=20

# ─── SECURITY / PRODUCTION HARDENING ───
# Se impostato, protegge endpoint admin/sensibili con header x-vio-admin-pin
VIO_ADMIN_PIN=

# Rate limit chat per IP (middleware backend)
VIO_RATE_LIMIT_CHAT_PER_MIN=30

# Limiti DB locali (manutenzione automatica)
VIO_MAX_KNOWLEDGE_DB_MB=500
VIO_PROCESS_LOG_MAX_MB=10
VIO_PROCESS_LOG_RETENTION_DAYS=7
VIO_PROCESS_LOG_MAINTENANCE_SEC=3600

# ─── TAURI UPDATER (DESKTOP APP) ───
# Endpoint multipli separati da virgola supportati (failover su non-2xx).
VIO_TAURI_UPDATER_ENABLED=true
VIO_TAURI_UPDATER_ENDPOINTS=https://github.com/vio83/vio83-ai-orchestra/releases/latest/download/latest.json

# Override opzionale della chiave pubblica updater (se ruoti la key).
# Lascia vuoto per usare la chiave fallback già inclusa in src-tauri.
VIO_TAURI_UPDATER_PUBKEY=

# ─── RELEASE SIGNING / NOTARIZATION (MACOS) ───
# NOTA: queste variabili si usano in locale/CI per firmare e notarizzare.
# Non inserirle nel repo, solo in ambiente sicuro o secrets CI.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=
APPLE_API_ISSUER=
APPLE_API_KEY=
APPLE_API_KEY_PATH=
