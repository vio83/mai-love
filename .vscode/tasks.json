
{
  // ============================================================
  // VIO 83 AI ORCHESTRA — Build & Run Tasks
  // Ctrl+Shift+B per build, o usa Command Palette
  // ============================================================
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite-dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+): (error|warning) (.+)$",
          "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "vite-build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "backend-dev",
      "type": "shell",
      "command": "bash scripts/runtime/start_backend_dev_safe.sh",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONPATH": "${workspaceFolder}" }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "backend-reset",
      "type": "shell",
      "command": "bash scripts/runtime/backend_reset_panic.sh",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONPATH": "${workspaceFolder}" }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "backend-certify-runtime",
      "type": "shell",
      "command": "bash scripts/runtime/certify_runtime_local_only.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "backend"
      }
    },
    {
      "label": "tauri-dev",
      "type": "npm",
      "script": "tauri:dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "tauri"
      }
    },
    {
      "label": "tauri-build",
      "type": "npm",
      "script": "tauri:build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "ollama-start",
      "type": "shell",
      "command": "ollama serve",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "ai"
      }
    },
    {
      "label": "ollama-pull-models",
      "type": "shell",
      "command": "ollama pull qwen2.5-coder:3b && ollama pull llama3.2:3b && ollama pull gemma2:2b",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "🎵 Start Full Orchestra",
      "dependsOn": ["ollama-start", "backend-dev", "vite-dev"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "rm -rf dist node_modules/.cache",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "real-max-global-activate",
      "type": "shell",
      "command": "bash scripts/runtime/activate_real_max_global_mode.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "real-max-maintenance-now",
      "type": "shell",
      "command": "bash scripts/runtime/run_real_max_maintenance.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "⚡ Power 360 Activate",
      "dependsOn": [
        "real-max-global-activate",
        "🎵 Start Full Orchestra"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "bootstrap-vscode-check",
      "type": "shell",
      "command": "bash scripts/setup/bootstrap_vscode_mac.sh check",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "bootstrap-vscode-install",
      "type": "shell",
      "command": "bash scripts/setup/bootstrap_vscode_mac.sh install",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "monetization-readiness",
      "type": "shell",
      "command": "bash scripts/monetization/run_monetization_readiness.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "vscode-autofix-now",
      "type": "shell",
      "command": "bash scripts/runtime/vscode_autofix_cycle.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONPATH": "${workspaceFolder}" }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "install-vscode-autofix-autopilot",
      "type": "shell",
      "command": "bash scripts/runtime/install_vscode_autofix_autopilot.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
