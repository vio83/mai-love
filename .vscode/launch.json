{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Backend FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.api.server:app",
        "--reload",
        "--port",
        "4000"
      ],
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "BRACE MVP (Port 9551)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/brace-v3/prototipo_web_advanced.py",
      "console": "integratedTerminal",
      "env": {
        "GIULIA_PROTO_PORT": "9551",
        "PYTHONUNBUFFERED": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "BRACE WebUI (Port 9443)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/brace-v3/webui.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Vite Frontend (Port 5173)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + BRACE MVP)",
      "configurations": [
        "Python: Backend FastAPI",
        "BRACE MVP (Port 9551)"
      ]
    }
  ]
}
