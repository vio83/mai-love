{
  // ============================================================
  // VIO 83 AI ORCHESTRA — VS Code Workspace Settings
  // Configurazione ultra-ottimizzata per il progetto
  // ============================================================

  // === EDITOR ===
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.minimap.enabled": false,
  "editor.wordWrap": "on",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.renderWhitespace": "boundary",
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": true,

  // === TYPESCRIPT / JAVASCRIPT ===
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.suggest.autoImports": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },

  // (JavaScript settings unified under js/ts.* above)

  // === REACT / JSX / TSX ===
  "emmet.includeLanguages": {
    "typescriptreact": "html",
    "javascriptreact": "html"
  },
  "emmet.triggerExpansionOnTab": true,

  // === TAILWIND CSS ===
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["className\\s*=\\s*{?[\"'`]([^\"'`]*)[\"'`]"]
  ],
  "tailwindCSS.emmetCompletions": true,
  "css.validate": false,

  // === PYTHON ===
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },

  // === RUST (Tauri backend) ===
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },

  // === ESLint ===
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": ["."],

  // === GIT ===
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "gitlens.currentLine.enabled": true,
  "gitlens.hovers.enabled": true,

  // === FILE ASSOCIATIONS ===
  "files.associations": {
    "*.css": "tailwindcss",
    "*.env*": "dotenv"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/target": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/target/**": true,
    "**/.git/objects/**": true
  },

  // === SEARCH ===
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/target": true,
    "**/.git": true,
    "**/package-lock.json": true
  },

  // === TERMINAL ===
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'SF Mono', Menlo",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.osx": {
    "OLLAMA_HOST": "http://localhost:11434"
  },

  // === THEME (Vio Dark Fluorescent) ===
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",

  // === ERROR LENS ===
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.fontSize": "12",

  // === TODO TREE ===
  "todo-tree.general.tags": ["TODO", "FIXME", "HACK", "BUG", "XXX", "VIO"],
  "todo-tree.highlights.customHighlight": {
    "VIO": {
      "icon": "zap",
      "foreground": "#00ff00",
      "iconColour": "#00ff00"
    }
  },

  // === SPELL CHECKER ===
  "cSpell.language": "en,it",
  "cSpell.enabledFileTypes": {
    "typescript": true,
    "typescriptreact": true,
    "javascript": true,
    "python": true,
    "json": true,
    "markdown": true,
    "yaml": true,
    "html": true,
    "css": true,
    "rust": true
  },
  "cSpell.ignorePaths": [
    "node_modules",
    "dist",
    "target",
    "package-lock.json",
    "*.min.js",
    "*.min.css",
    "data/**",
    "**/__pycache__/**"
  ],
  "cSpell.words": [
    "vio83",
    "tauri",
    "ollama",
    "litellm",
