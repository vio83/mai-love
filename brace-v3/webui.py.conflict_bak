"""
BRACE v3.0 — Web UI Secure Server VERSION 2
DEMO Edition (localhost:9443 HTTPS) + PROTOTIPO (localhost:9444)
Privacy Bunker + Security Bunker + Developer Auth System
"""

import http.server
import json
import socketserver
import ssl
import subprocess
import sys
import time
import hmac
import hashlib
from pathlib import Path
from datetime import datetime

BRACE_DIR = Path(__file__).resolve().parent
if str(BRACE_DIR) not in sys.path:
    sys.path.insert(0, str(BRACE_DIR))

from brace_v3 import BRACE_v30, ImplicitProfile, WindowState
from scenarios_db import SCENARIOS

PORT = 9443  # DEMO on 9443, PROTOTIPO on 9444
MODE = "DEMO"  # Set to "PROTOTIPO" for second instance

CERT_DIR = BRACE_DIR / ".security_certs"
CERT_FILE = CERT_DIR / "brace_localhost.pem"
KEY_FILE = CERT_DIR / "brace_localhost_key.pem"

# Developer Auth System
DEVELOPER_CREDENTIALS = {
    "dev_master": hashlib.sha256("dev@VIO83_MASTER_2026".encode()).hexdigest(),
    "dev_proto": hashlib.sha256("proto@BRACE_v3.0_DEV".encode()).hexdigest(),
}

class BraceState:
    def __init__(self):
        self.engine = BRACE_v30()
        self.state = {
            "phase": 1,
            "trust_score": 50.0,
            "iai_score": 0.10,
            "history": [],
            "current_scenario": None,
            "current_turn": 0
        }
        self.current_scenario = None
        self.current_turn = 0

    def process_input(self, text):
        output = self.engine.process(text, self.state)
        self.state["history"].append(text)
        self.state["trust_score"] = output.relational_state.get("trust_score", 50.0)
        self.state["phase"] = output.relational_state.get("phase", 1)
        self.state["iai_score"] = output.iai_state.get("score", 0.10)
        return {
            "phase": output.relational_state.get("phase"),
            "trust": output.relational_state.get("trust_score"),
            "iai": output.iai_state.get("score"),
            "window_gaming": output.pil_result.get("window_gaming", False),
            "pil_mode": output.pil_result.get("mode"),
            "prevention": output.system_prompt[:100] + "..."
        }

    def load_scenario(self, scenario_name):
        if scenario_name in SCENARIOS:
            self.current_scenario = scenario_name
            self.current_turn = 0
            return SCENARIOS[scenario_name]
        return None

brace_state = BraceState()

class ReusableTCPServer(socketserver.TCPServer):
    allow_reuse_address = True

class SecureBraceHandler(http.server.SimpleHTTPRequestHandler):
    def add_security_headers(self):
        self.send_header('X-Content-Type-Options', 'nosniff')
        self.send_header('X-Frame-Options', 'DENY')
        self.send_header('X-XSS-Protection', '1; mode=block')
        self.send_header('Strict-Transport-Security', 'max-age=31536000; includeSubDomains')
        self.send_header('Content-Security-Policy', "default-src 'self'; style-src 'unsafe-inline'")
        self.send_header('Referrer-Policy', 'no-referrer')

    def verify_dev_auth(self, token: str) -> bool:
        """Verifica developer authentication token"""
        for username, password_hash in DEVELOPER_CREDENTIALS.items():
            if hmac.compare_digest(token, password_hash):
                return True
        return False

    def do_GET(self):
        if not self.client_address[0] in ('127.0.0.1', '::1'):
            self.send_response(403)
            self.end_headers()
            return

        if self.path == '/':
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.add_security_headers()
            self.end_headers()
            self.wfile.write(HTML_TEMPLATE.encode('utf-8'))

        elif self.path == '/api/state':
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.add_security_headers()
            self.end_headers()
            state_data = {
                "version": "3.0",
                "mode": MODE,
                "phase": brace_state.state["phase"],
                "trust_score": brace_state.state["trust_score"],
                "iai_score": brace_state.state["iai_score"],
                "history_length": len(brace_state.state["history"]),
                "timestamp": datetime.now().isoformat()
            }
            self.wfile.write(json.dumps(state_data).encode('utf-8'))

        elif self.path.startswith('/api/scenarios'):
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.add_security_headers()
            self.end_headers()
            self.wfile.write(json.dumps(list(SCENARIOS.keys())).encode('utf-8'))

    def do_POST(self):
        if not self.client_address[0] in ('127.0.0.1', '::1'):
            self.send_response(403)
            self.end_headers()
            return

        content_length = int(self.headers.get('Content-Length', 0))
        if content_length > 10000:
            self.send_response(413)
            self.end_headers()
            return

        try:
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)

            if self.path == '/api/input':
                text = data.get('text', '').strip()[:1000]
                if not text:
                    self.send_response(400)
                    self.end_headers()
                    return

                result = brace_state.process_input(text)
                self.send_response(200)
                self.send_header('Content-type', 'application/json')
                self.add_security_headers()
                self.end_headers()
                self.wfile.write(json.dumps(result).encode('utf-8'))

            elif self.path == '/api/load_scenario':
                scenario_name = data.get('scenario', '').strip()
                if scenario_name not in SCENARIOS:
                    self.send_response(400)
                    self.end_headers()
                    return

                scenario = brace_state.load_scenario(scenario_name)
                self.send_response(200)
                self.send_header('Content-type', 'application/json')
                self.add_security_headers()
                self.end_headers()

                if scenario:
                    turns = [turn[0] for turn in scenario]
                    self.wfile.write(json.dumps({"success": True, "turns": turns}).encode('utf-8'))
                else:
                    self.wfile.write(json.dumps({"success": False}).encode('utf-8'))

            elif self.path == '/api/dev/modify':
                # Developer modification endpoint
                token = data.get('token', '')
                if not self.verify_dev_auth(token):
                    self.send_response(401)
                    self.end_headers()
                    return

                action = data.get('action')
                payload = data.get('payload', {})

                response = self._handle_dev_action(action, payload)

                self.send_response(200)
                self.send_header('Content-type', 'application/json')
                self.add_security_headers()
                self.end_headers()
                self.wfile.write(json.dumps(response).encode('utf-8'))

        except Exception as e:
            self.send_response(400)
            self.end_headers()

    def _handle_dev_action(self, action: str, payload: dict) -> dict:
        """Handle developer actions - modify background properties"""
        try:
            if action == "modify_background":
                # Modifica sfondo online
                return {
                    "success": True,
                    "action": "background",
                    "message": f"Background modified: {payload.get('color', 'default')}"
                }
            elif action == "apply_theme":
                return {
                    "success": True,
                    "action": "theme",
                    "message": f"Theme applied: {payload.get('theme', 'default')}"
                }
            elif action == "execute_code":
                # Dynamic code execution backend (dangerous - requires token)
                command = payload.get('code', '')
                return {
                    "success": True,
                    "action": "code",
                    "message": f"Code queued for execution"
                }
            else:
                return {"success": False, "error": "Unknown action"}
        except Exception as e:
            return {"success": False, "error": str(e)}

