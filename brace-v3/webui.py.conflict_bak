        print(f"  📍 Access: https://localhost:{PORT}/")
        print(f"  🔒 Security: Privacy Bunker + Security Bunker Active")
        print(f"\n  ⚠️  Browser Certificate Warning: NORMAL for localhost self-signed cert")
        print(f"  💡 This is HONEST and TRANSPARENT - self-generated local certificate")
