        }

        .scenario-list ul {
            list-style: none;
            padding-left: 0;
        }

        .scenario-list li {
            padding: 6px 0;
            color: #555;
            border-bottom: 1px solid #f0f0f0;
        }

        .scenario-list li:last-child {
            border-bottom: none;
        }

        .status-online {
            display: inline-block;
            width: 10px;
            height: 10px;
            background: #4caf50;
            border-radius: 50%;
            margin-right: 8px;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.3);
        }

        .info-box {
            background: #f5f9ff;
            border-left: 4px solid #2196f3;
            padding: 14px;
            border-radius: 4px;
            margin: 16px 0;
            font-size: 0.9rem;
            color: #1565c0;
            line-height: 1.5;
        }

        .timestamp {
            font-size: 0.85rem;
            color: #999;
            margin-top: 8px;
            font-variant-numeric: tabular-nums;
        }

        @media (max-width: 1024px) {
            .panels {
                grid-template-columns: 1fr;
            }

            .input-area {
                grid-column: 1;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            * {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎯 BRACE v3.0 — Behavioral Reciprocity Engine</h1>
            <p>Advanced Psychological Pattern Detection & Prevention System</p>
            <div class="security-badges">
                <span class="badge">🔐 HTTPS Secure</span>
                <span class="badge">🛡️ Privacy Bunker</span>
                <span class="badge">⚔️ Security Bunker</span>
                <span class="badge">👨‍💻 Dev Authenticated</span>
                <span class="badge">✅ Offline Capable</span>
            </div>
        </div>

        <div class="panels">
            <div class="panel">
                <h2>📊 Real-Time State</h2>
                <div class="metric">
                    <span class="metric-label"><span class="status-online"></span>Status</span>
                    <span class="metric-value">Active</span>
                </div>
                <div class="metric">
                    <span class="metric-label">Relational Phase</span>
                    <span class="metric-value" id="phase">1</span>
                </div>
                <div class="metric">
                    <span class="metric-label">Trust Score</span>
                    <span class="metric-value" id="trust">50.0</span>
                </div>
                <div class="metric">
                    <span class="metric-label">IAI (Attachment)</span>
                    <span class="metric-value" id="iai">0.10</span>
                </div>
                <div class="metric">
                    <span class="metric-label">History Turns</span>
                    <span class="metric-value" id="history">0</span>
                </div>
                <div class="timestamp" id="timestamp">—</div>
            </div>

            <div class="panel">
                <h2>⚙️ Scenario Control</h2>
                <label>Select Scenario:</label>
                <select id="scenario-select">
                    <option value="">— Manual Input Mode —</option>
                </select>
                <button onclick="loadScenario()">📂 Load Scenario</button>
                <div class="scenario-list">
                    <strong>Available Scenarios:</strong>
                    <ul id="scenario-list"></ul>
                </div>
            </div>

            <div class="input-area panel">
                <h2>💬 Input Processing</h2>
                <input type="text" id="input" placeholder="Enter text to analyze..." />
                <button onclick="processInput()">▶️ Process & Analyze</button>
                <div class="info-box">
                    <strong>ℹ️ How it works:</strong> Type any text and press Enter or click Process. BRACE analyzes for psychological patterns, emotionalvulnerability indicators, and potential exploitation markers in real-time.
                </div>
            </div>
        </div>
    </div>

    <script>
        async function updateState() {
            try {
                const resp = await fetch('/api/state');
                const data = await resp.json();
                document.getElementById('phase').innerText = data.phase;
                document.getElementById('trust').innerText = data.trust_score.toFixed(1);
                document.getElementById('iai').innerText = data.iai_score.toFixed(2);
                document.getElementById('history').innerText = data.history_length;
                document.getElementById('timestamp').innerText = new Date().toLocaleTimeString('it-IT');
            } catch(e) {
                console.error('State update error:', e);
            }
        }

        async function loadScenarios() {
            try {
                const resp = await fetch('/api/scenarios');
                const scenarios = await resp.json();
                const select = document.getElementById('scenario-select');
                const list = document.getElementById('scenario-list');

                scenarios.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s;
                    opt.innerText = s.replace(/_/g, ' ').toUpperCase();
                    select.appendChild(opt);

                    const li = document.createElement('li');
                    li.innerText = '• ' + s.replace(/_/g, ' ');
                    list.appendChild(li);
                });
            } catch(e) {
                console.error('Load scenarios error:', e);
            }
        }

        async function processInput() {
            const text = document.getElementById('input').value.trim();
            if (!text) {
                alert('Please enter some text to analyze');
                return;
            }

            try {
                const resp = await fetch('/api/input', {
                    method: 'POST',
                    body: JSON.stringify({text: text})
                });

                if (resp.ok) {
                    document.getElementById('input').value = '';
                    await new Promise(r => setTimeout(r, 100));
                    updateState();
                }
            } catch(e) {
                console.error('Process input error:', e);
                alert('Error processing input');
            }
        }

        async function loadScenario() {
            const scenario = document.getElementById('scenario-select').value;
            if (!scenario) {
                alert('Please select a scenario');
                return;
            }

            try {
                const resp = await fetch('/api/load_scenario', {
                    method: 'POST',
                    body: JSON.stringify({scenario: scenario})
                });

                const data = await resp.json();
                if (data.success) {
                    alert('Scenario loaded: ' + scenario.replace(/_/g, ' ').toUpperCase() + ' (' + data.turns.length + ' turns)');
                    updateState();
                } else {
                    alert('Error loading scenario');
                }
            } catch(e) {
                console.error('Load scenario error:', e);
                alert('Error loading scenario');
            }
        }

        document.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && e.target.id === 'input') {
                processInput();
            }
        });

        // Initialize
        loadScenarios();
        updateState();
        setInterval(updateState, 1500);
    </script>
</body>
</html>
"""

def create_self_signed_cert():
    """Crea certificato auto-firmato locale"""
    if CERT_FILE.exists() and KEY_FILE.exists():
        return True

    CERT_DIR.mkdir(exist_ok=True)

    try:
        cmd = [
            "openssl", "req", "-x509", "-newkey", "rsa:2048",
            "-keyout", str(KEY_FILE), "-out", str(CERT_FILE),
            "-days", "365", "-nodes",
            "-subj", "/C=IT/ST=Local/L=Localhost/O=BRACE/CN=localhost"
        ]
        subprocess.run(cmd, check=True, capture_output=True)
        CERT_FILE.chmod(0o600)
        KEY_FILE.chmod(0o600)
        return True
    except Exception as e:
        print(f"❌ Certificato error: {e}")
        return False

