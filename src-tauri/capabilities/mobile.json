{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Mobile-specific permissions for iOS and Android",
  "platforms": ["iOS", "android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://192.168.*:*" },
        { "url": "http://10.*:*" },
        { "url": "https://*" }
      ]
    },
    "shell:allow-open"
  ]
}
